# Arduino CLI build config — ESP32-C6-DevKitC-1 (N8, 8MB flash)

PROJECT_DIR=".."
SKETCH_NAME="Clock.ino"

# Default 8MB partition scheme already includes OTA app1 + app2 partitions.
FQBN="esp32:esp32:esp32c6:FlashSize=8M,PartitionScheme=default_8MB"

# Default device IP for OTA upload (override via CLI arg to upload.sh)
DEVICE_IP=""
